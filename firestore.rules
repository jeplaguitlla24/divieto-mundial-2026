rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── DATOS PÚBLICOS ──────────────────────────────────────────────────────
    // Escritura solo desde Firebase Admin SDK (live-scoring.js, consola manual)
    // allow write: if false no afecta al Admin SDK — este bypasea las reglas

    match /config/{docId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email in ['pepepresta@gmail.com', 'jeplaguitlla@gmail.com'];
    }

    match /puntuaciones/{jornada} {
      allow read: if true;
      allow write: if false;
    }

    match /enfermeria/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /resultados/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /torneo/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── DRAFTS ──────────────────────────────────────────────────────────────
    // Lectura: cualquier usuario autenticado (pantalla Jornada lee drafts ajenos
    //          para calcular clasificación de liga)
    // Escritura/borrado: solo el propietario del draft

    match /drafts/{uid} {
      allow read:  if request.auth != null;
      // Solo se puede escribir dentro de la ventana de draft:
      //   apertura ≤ ahora < deadline  (ambos guardados en config/jornada)
      allow write: if request.auth != null
        && request.auth.uid == uid
        && exists(/databases/$(database)/documents/config/jornada)
        && get(/databases/$(database)/documents/config/jornada).data.apertura != null
        && request.time.toMillis() >= get(/databases/$(database)/documents/config/jornada).data.apertura
        && request.time.toMillis() < get(/databases/$(database)/documents/config/jornada).data.deadline;
    }

    // ── CÓDIGOS DE ACCESO ───────────────────────────────────────────────────
    // Lectura: pública (el código es el secreto en sí)
    // Actualización: solo para marcar como usado (uid null → uid del usuario)

    match /codigos/{codigo} {
      allow read: if true;
      // Código reutilizable: permite reclamar el código aunque ya tenga uid
      // (sesión perdida en otro dispositivo, nueva sesión anónima con el mismo código)
      allow update: if request.auth != null
        && resource.data.activo == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uid', 'usadoAt'])
        && request.resource.data.uid == request.auth.uid;
    }

    // ── PERFILES DE USUARIO ─────────────────────────────────────────────────
    // Lectura: cualquier autenticado
    // Crear/actualizar: solo el propio usuario

    match /users/{uid} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
    }

    // ── ÍNDICE DE NOMBRES DE USUARIO ────────────────────────────────────────
    // Lectura pública (comprobación de disponibilidad antes de crear cuenta)
    // Crear: solo el propietario (uid en el doc == uid del auth)
    // No se puede modificar ni borrar desde cliente

    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── LIGAS ───────────────────────────────────────────────────────────────
    // Lectura: cualquier autenticado
    // Crear:   autenticado + el creador debe incluirse en managers[]
    // Actualizar:
    //   • Un manager existente puede modificar la configuración de su liga
    //   • Un nuevo usuario puede añadirse a sí mismo via código (join):
    //     solo puede agregar su propio uid y no puede eliminar managers existentes
    // Borrar:  nunca desde cliente

    match /ligas/{ligaId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.managers;

      allow update: if request.auth != null && (
        // Manager: puede modificar su propio managersInfo o el nombre de la liga
        (request.auth.uid in resource.data.managers
         && request.resource.data.managers == resource.data.managers
         && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['managersInfo', 'nombre']))
        ||
        // Join: se añade solo a sí mismo sin borrar a nadie
        (request.resource.data.managers.hasAll(resource.data.managers)
         && request.resource.data.managers.size() == resource.data.managers.size() + 1
         && request.auth.uid in request.resource.data.managers
         && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['managers', 'managersInfo']))
      );

      allow delete: if false;
    }

    // ── OVERRIDES ADMIN ─────────────────────────────────────────────────────
    // Lectura: cualquier autenticado (para aplicar overrides en la app)
    // Escritura: solo los dos admins

    match /overrides/{docId} {
      allow read:  if true;
      allow write: if request.auth != null
        && request.auth.token.email in ['pepepresta@gmail.com', 'jeplaguitlla@gmail.com'];
    }

    // ── BLOQUEO GLOBAL ──────────────────────────────────────────────────────
    // Cualquier colección no declarada arriba queda bloqueada

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
