rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ─────────────────────────────────────────────────────────────

    function validFormacion(f) {
      return f is string && f in ['4-4-2', '4-3-3', '3-4-3'];
    }

    function allSlots(sc, f) {
      return f == '4-4-2'
        ? sc.keys().hasAll(['T-PT-0','T-DF-0','T-DF-1','T-DF-2','T-DF-3','T-MC-0','T-MC-1','T-MC-2','T-MC-3','T-DL-0','T-DL-1'])
        : f == '4-3-3'
          ? sc.keys().hasAll(['T-PT-0','T-DF-0','T-DF-1','T-DF-2','T-DF-3','T-MC-0','T-MC-1','T-MC-2','T-DL-0','T-DL-1','T-DL-2'])
          : sc.keys().hasAll(['T-PT-0','T-DF-0','T-DF-1','T-DF-2','T-MC-0','T-MC-1','T-MC-2','T-MC-3','T-DL-0','T-DL-1','T-DL-2']);
    }

    function ovrOk(sc, f) {
      return f == '4-4-2'
        ? (sc['T-PT-0'].overall + sc['T-DF-0'].overall + sc['T-DF-1'].overall + sc['T-DF-2'].overall + sc['T-DF-3'].overall +
           sc['T-MC-0'].overall + sc['T-MC-1'].overall + sc['T-MC-2'].overall + sc['T-MC-3'].overall +
           sc['T-DL-0'].overall + sc['T-DL-1'].overall) <= 900
        : f == '4-3-3'
          ? (sc['T-PT-0'].overall + sc['T-DF-0'].overall + sc['T-DF-1'].overall + sc['T-DF-2'].overall + sc['T-DF-3'].overall +
             sc['T-MC-0'].overall + sc['T-MC-1'].overall + sc['T-MC-2'].overall +
             sc['T-DL-0'].overall + sc['T-DL-1'].overall + sc['T-DL-2'].overall) <= 900
          : (sc['T-PT-0'].overall + sc['T-DF-0'].overall + sc['T-DF-1'].overall + sc['T-DF-2'].overall +
             sc['T-MC-0'].overall + sc['T-MC-1'].overall + sc['T-MC-2'].overall + sc['T-MC-3'].overall +
             sc['T-DL-0'].overall + sc['T-DL-1'].overall + sc['T-DL-2'].overall) <= 900;
    }

    function noDups(sc, f) {
      return f == '4-4-2'
        ? [sc['T-PT-0'].id, sc['T-DF-0'].id, sc['T-DF-1'].id, sc['T-DF-2'].id, sc['T-DF-3'].id,
           sc['T-MC-0'].id, sc['T-MC-1'].id, sc['T-MC-2'].id, sc['T-MC-3'].id,
           sc['T-DL-0'].id, sc['T-DL-1'].id].toSet().size() == 11
        : f == '4-3-3'
          ? [sc['T-PT-0'].id, sc['T-DF-0'].id, sc['T-DF-1'].id, sc['T-DF-2'].id, sc['T-DF-3'].id,
             sc['T-MC-0'].id, sc['T-MC-1'].id, sc['T-MC-2'].id,
             sc['T-DL-0'].id, sc['T-DL-1'].id, sc['T-DL-2'].id].toSet().size() == 11
          : [sc['T-PT-0'].id, sc['T-DF-0'].id, sc['T-DF-1'].id, sc['T-DF-2'].id,
             sc['T-MC-0'].id, sc['T-MC-1'].id, sc['T-MC-2'].id, sc['T-MC-3'].id,
             sc['T-DL-0'].id, sc['T-DL-1'].id, sc['T-DL-2'].id].toSet().size() == 11;
    }

    function confirmedValid(data) {
      let sc = data.slotCards;
      let f  = data.formacion;
      return sc is map
        && sc.size() == 11
        && validFormacion(f)
        && allSlots(sc, f)
        && ovrOk(sc, f)
        && noDups(sc, f);
    }

    // ── DATOS PÚBLICOS ──────────────────────────────────────────────────────
    // Escritura solo desde Firebase Admin SDK (live-scoring.js, consola manual)
    // allow write: if false no afecta al Admin SDK — este bypasea las reglas

    match /config/{docId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email in ['pepepresta@gmail.com', 'jeplaguitlla@gmail.com'];
    }

    match /puntuaciones/{jornada} {
      allow read: if true;
      allow write: if false;
    }

    match /enfermeria/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /resultados/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /torneo/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── DRAFTS ──────────────────────────────────────────────────────────────
    // Lectura: cualquier usuario autenticado
    // Escritura: propietario + dentro de ventana + formación válida
    // Si alineacionConfirmada=true: valida 11 slots, OVR ≤ 900, sin duplicados

    match /drafts/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && exists(/databases/$(database)/documents/config/jornada)
        && get(/databases/$(database)/documents/config/jornada).data.apertura != null
        && request.time.toMillis() >= get(/databases/$(database)/documents/config/jornada).data.apertura
        && request.time.toMillis() < get(/databases/$(database)/documents/config/jornada).data.deadline
        && validFormacion(request.resource.data.formacion)
        && (request.resource.data.get('alineacionConfirmada', false) != true
            || confirmedValid(request.resource.data));
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // ── CÓDIGOS DE ACCESO ───────────────────────────────────────────────────
    match /codigos/{codigo} {
      allow read: if true;
      allow update: if request.auth != null
        && resource.data.activo == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uid', 'usadoAt'])
        && request.resource.data.uid == request.auth.uid;
    }

    // ── PERFILES DE USUARIO ─────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
    }

    // ── ÍNDICE DE NOMBRES DE USUARIO ────────────────────────────────────────
    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── LIGAS ───────────────────────────────────────────────────────────────
    match /ligas/{ligaId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.managers;

      allow update: if request.auth != null && (
        (request.auth.uid in resource.data.managers
         && request.resource.data.managers == resource.data.managers
         && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['managersInfo', 'nombre']))
        ||
        (request.resource.data.managers.hasAll(resource.data.managers)
         && request.resource.data.managers.size() == resource.data.managers.size() + 1
         && request.auth.uid in request.resource.data.managers
         && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['managers', 'managersInfo']))
      );

      allow delete: if false;
    }

    // ── OVERRIDES ADMIN ─────────────────────────────────────────────────────
    match /overrides/{docId} {
      allow read:  if true;
      allow write: if request.auth != null
        && request.auth.token.email in ['pepepresta@gmail.com', 'jeplaguitlla@gmail.com'];
    }

    // ── BLOQUEO GLOBAL ──────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
