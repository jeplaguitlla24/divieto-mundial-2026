{
  "functions": {
    "source": ".",
    "runtime": "nodejs22",
    "ignore": [
      "node_modules",
      ".git",
      "public/assets",
      "public/app",
      "test",
      "playwright-report",
      "*.bat",
      "*.sh",
      ".secrets"
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "emulators": {
    "firestore": {
      "port": 8080,
      "host": "127.0.0.1"
    },
    "ui": {
      "enabled": false
    }
  },
  "hosting": {
    "predeploy": ["node scripts/convert-to-webp.js"],
    "public": "public",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
"assets/img/players/**/*.png",
      "assets/img/players/**/*.jpg",
      "assets/img/players/**/*.jpeg",
      "assets/img/escudos/**/*.png",
      "assets/img/CARTAS PNG/*.png",
      "assets/logo/splash2.mp4",
      "assets/logo/splash2.png",
      "assets/img/fondo-index.png"
    ],
    "headers": [
      {
        "source": "**/*.avif",
        "headers": [
          { "key": "Content-Type", "value": "image/avif" }
        ]
      },
      {
        "source": "**/*.@(js|css|html)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
        ]
      },
      {
        "source": "**/*.@(png|jpg|jpeg|webp|svg|ico|woff2|woff)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**/*.mp4",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ]
  }
}
